# Required (docker-compose default)
DATABASE_URL=postgres://knoldr:knoldr@localhost:5432/knoldr

# Required: web search API key (https://langsearch.com/dashboard)
LANGSEARCH_API_KEY=sk-your-key-here

# ----- Local LLM (default path) -----
# Ollama is the primary and only required LLM. Default points at the
# host's Ollama via docker's host-gateway alias.
# OLLAMA_HOST=http://host.docker.internal:11434
# KNOLDR_OLLAMA_FAST_MODEL=gemma4:e4b
# KNOLDR_OLLAMA_JURY_MODELS=gemma4:e4b,qwen2.5:14b
# KNOLDR_OLLAMA_TIMEOUT_MS=120000

# ----- Cloud CLI fallback (opt-in) -----
# The verifier can optionally fan out to OpenAI Codex and/or Google
# Gemini CLIs as additional jury voters. OFF by default because:
#   1. Free-tier quotas exhaust quickly under production load.
#   2. Subprocess spawn overhead per call.
#   3. Adds latency when Ollama is healthy.
# To enable: set KNOLDR_ENABLE_CLOUD_CLI and provide the binary +
# model for each cloud path you want active.
# KNOLDR_ENABLE_CLOUD_CLI=1
# KNOLDR_CODEX_CLI=codex
# KNOLDR_CLOUD_CODEX_MODEL=gpt-5.4-mini
# KNOLDR_GEMINI_CLI=gemini
# KNOLDR_CLOUD_GEMINI_MODEL=gemini-2.5-flash-lite

# ----- Server -----
# KNOLDR_API_TOKEN=your-bearer-token
# KNOLDR_PORT=5100
# KNOLDR_HOST=0.0.0.0
# KNOLDR_LOG_LEVEL=info

# ----- SSRF allowlist (opt-in) -----
# Comma-separated hostnames the claim verifier may fetch despite
# resolving to private / loopback IPs. Use only for trusted intranet
# sources (e.g. internal wiki).
# KNOLDR_ALLOWED_INTERNAL_HOSTS=wiki.internal,docs.internal
