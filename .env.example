# Required (docker-compose default)
DATABASE_URL=postgres://knoldr:knoldr@localhost:5432/knoldr

# Required: web search API key (https://langsearch.com/dashboard)
LANGSEARCH_API_KEY=sk-your-key-here

# Optional (defaults shown)
# KNOLDR_CODEX_CLI=codex
# KNOLDR_GEMINI_CLI=gemini
# KNOLDR_API_TOKEN=your-bearer-token
# KNOLDR_PORT=5100
# KNOLDR_HOST=0.0.0.0
# KNOLDR_LOG_LEVEL=info
