{
  "name": "knoldr",
  "module": "src/index.ts",
  "type": "module",
  "private": true,
  "bin": {
    "knoldr": "src/cli/index.ts"
  },
  "scripts": {
    "dev": "bun run src/index.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun run src/db/migrate.ts",
    "db:push": "drizzle-kit push",
    "test": "bun test",
    "test:unit": "bun test tests/unit/",
    "test:integration": "bun test tests/integration/",
    "test:e2e": "bun test tests/e2e/",
    "docker:up": "docker compose up -d --wait db",
    "docker:down": "docker compose down",
    "docker:test": "docker compose --profile test up -d --wait db-test",
    "setup": "docker compose up -d --wait db && bun run db:migrate",
    "test:db": "docker compose --profile test up -d --wait db-test && TEST_DATABASE_URL=postgres://knoldr:knoldr@localhost:5433/knoldr_test bun test tests/integration/ tests/e2e/"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "drizzle-kit": "^0.31.10"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2",
    "pino": "^10.3.1",
    "postgres": "^3.4.8",
    "prom-client": "^15.1.3",
    "ulid": "^3.0.2",
    "zod": "^4.3.6"
  }
}
